{{ 'hiring-test.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hiring-test.js' | asset_url }}" defer></script>

<section class="hiring-test-page hiring-test-grid">
  {% if section.settings.heading != blank %}
    <h2 class="hiring-test-grid__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="hiring-test-grid__items">
    {% for block in section.blocks %}
      {% assign selected_product = block.settings.product %}
      {% assign fallback_image = '' %}
      {% case forloop.index %}
        {% when 1 %}
          {% assign fallback_image = 'gift-grid-1.png' %}
        {% when 2 %}
          {% assign fallback_image = 'gift-grid-2.png' %}
        {% when 3 %}
          {% assign fallback_image = 'gift-grid-3.png' %}
        {% when 4 %}
          {% assign fallback_image = 'gift-grid-4.png' %}
        {% when 5 %}
          {% assign fallback_image = 'gift-grid-5.png' %}
        {% when 6 %}
          {% assign fallback_image = 'gift-grid-6.png' %}
      {% endcase %}

      <article class="hiring-test-card" {{ block.shopify_attributes }}>
        <div class="hiring-test-card__image">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag: loading: 'lazy', sizes: '(max-width: 989px) 50vw, 33vw', alt: selected_product.title
            }}
          {% elsif selected_product != blank and selected_product.featured_image != blank %}
            {{
              selected_product.featured_image
              | image_url: width: 900
              | image_tag: loading: 'lazy', sizes: '(max-width: 989px) 50vw, 33vw', alt: selected_product.title
            }}
          {% elsif fallback_image != blank %}
            <img
              src="{{ fallback_image | asset_url }}"
              alt="Gift style look {{ forloop.index }}"
              width="186"
              height="186"
              loading="lazy"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <button
            class="hiring-test-card__hotspot"
            type="button"
            {% if selected_product != blank %}
              aria-label="Open {{ selected_product.title }} details"
              data-hiring-open-popup
              data-product-handle="{{ selected_product.handle }}"
            {% else %}
              aria-label="Select product in customizer"
              title="Select a product in this block to enable popup"
            {% endif %}
            style="
              --hotspot-top-desktop: {{ block.settings.hotspot_top }}%;
              --hotspot-left-desktop: {{ block.settings.hotspot_left }}%;
              --hotspot-top-mobile: {{ block.settings.hotspot_top_mobile }}%;
              --hotspot-left-mobile: {{ block.settings.hotspot_left_mobile }}%;
            "
          >
            +
          </button>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Hiring test grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (optional)"
        },
        {
          "type": "range",
          "id": "hotspot_top",
          "label": "Hotspot top (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 58
        },
        {
          "type": "range",
          "id": "hotspot_left",
          "label": "Hotspot left (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 72
        },
        {
          "type": "range",
          "id": "hotspot_top_mobile",
          "label": "Hotspot top mobile (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 18
        },
        {
          "type": "range",
          "id": "hotspot_left_mobile",
          "label": "Hotspot left mobile (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 82
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Hiring test grid"
    }
  ]
}
{% endschema %}
