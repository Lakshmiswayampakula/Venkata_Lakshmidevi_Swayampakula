{% comment %}
  Ecomexperts hiring test — Banner section (built from scratch).
  All primary copy is editable in the theme editor to match Figma red-box annotations.
{% endcomment %}

{{ 'ecomexperts-gift-guide.css' | asset_url | stylesheet_tag }}

{% liquid
  assign ee_show_chrome = section.settings.show_announcement_and_nav | default: true
%}

<section
  class="ee-banner{% unless ee_show_chrome %} ee-banner--hero-only{% endunless %}"
  id="shopify-section-{{ section.id }}"
  aria-labelledby="ee-banner-heading-{{ section.id }}"
>
  {% if ee_show_chrome %}
    <div class="ee-banner__announcement" style="--ee-announcement-bg: {{ section.settings.announcement_bg }};">
      <p class="ee-banner__announcement-text">{{ section.settings.announcement_text | escape }}</p>
    </div>

    <div class="ee-banner__nav-bar">
      <div class="ee-banner__nav-inner page-width">
        <a class="ee-banner__logo" href="{{ routes.root_url }}">
          {%- if section.settings.logo_image != blank -%}
            <img
              src="{{ section.settings.logo_image | image_url: width: 240 }}"
              alt="{{ section.settings.logo_text | escape }}"
              width="{{ section.settings.logo_image.width }}"
              height="{{ section.settings.logo_image.height }}"
              loading="eager"
              class="ee-banner__logo-img"
            >
          {%- else -%}
            <span class="ee-banner__logo-text">{{ section.settings.logo_text | escape }}</span>
          {%- endif -%}
        </a>

        <nav class="ee-banner__menu" aria-label="{{ section.settings.menu_aria_label | escape }}">
          <a class="ee-banner__menu-link" href="{{ section.settings.nav_link_1_url }}">{{ section.settings.nav_link_1_label | escape }}</a>
          <a class="ee-banner__menu-link" href="{{ section.settings.nav_link_2_url }}">{{ section.settings.nav_link_2_label | escape }}</a>
          <a class="ee-banner__menu-link" href="{{ section.settings.nav_link_3_url }}">{{ section.settings.nav_link_3_label | escape }}</a>
        </nav>

        <div class="ee-banner__utilities">
          <a class="ee-banner__icon-btn" href="{{ routes.search_url }}" aria-label="{{ section.settings.search_aria_label | escape }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Zm0-2.5a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" fill="currentColor"/>
              <path d="M15.97 15.97 21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
          <a class="ee-banner__icon-btn" href="{{ routes.account_url }}" aria-label="{{ section.settings.account_aria_label | escape }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4 0-7 2-7 4v1h14v-1c0-2-3-4-7-4Z" fill="currentColor"/>
            </svg>
          </a>
          <a class="ee-banner__icon-btn" href="{{ routes.cart_url }}" aria-label="{{ section.settings.cart_aria_label | escape }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 7h15l-1.5 9h-12L6 7Zm0 0L5 3H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
              <circle cx="17" cy="20" r="1.5" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="ee-banner__hero">
    <div class="ee-banner__hero-bg" aria-hidden="true">
      {%- if section.settings.hero_illustration != blank -%}
        <img
          class="ee-banner__hero-illustration"
          src="{{ section.settings.hero_illustration | image_url: width: 2400 }}"
          alt=""
          loading="lazy"
          width="{{ section.settings.hero_illustration.width }}"
          height="{{ section.settings.hero_illustration.height }}"
        >
      {%- endif -%}
    </div>

    <div class="ee-banner__hero-inner page-width">
      <div class="ee-banner__hero-copy">
        {%- if section.settings.kicker != blank -%}
          <p class="ee-banner__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        <h1 class="ee-banner__title" id="ee-banner-heading-{{ section.id }}">{{ section.settings.heading | escape }}</h1>
        <div class="ee-banner__description rte">{{ section.settings.description }}</div>
        <a
          class="ee-banner__cta ee-banner__cta--animated"
          href="{{ section.settings.cta_url }}"
        >
          <span class="ee-banner__cta-label">{{ section.settings.cta_label | escape }}</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ecomexperts — Gift guide banner",
  "tag": "section",
  "class": "section-ecomexperts-banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement_and_nav",
      "label": "Show announcement bar + in-section navigation",
      "default": true,
      "info": "Turn off if the theme header is visible so the page is not duplicated."
    },
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "FREE SHIPPING ON ALL ORDERS OVER $100"
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement background",
      "default": "#FFF566"
    },
    {
      "type": "header",
      "content": "Logo & navigation"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (fallback)",
      "default": "STORE"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "nav_link_1_label",
      "label": "Nav link 1 — label",
      "default": "SHOP"
    },
    {
      "type": "url",
      "id": "nav_link_1_url",
      "label": "Nav link 1 — URL"
    },
    {
      "type": "text",
      "id": "nav_link_2_label",
      "label": "Nav link 2 — label",
      "default": "ABOUT"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Nav link 2 — URL"
    },
    {
      "type": "text",
      "id": "nav_link_3_label",
      "label": "Nav link 3 — label",
      "default": "JOURNAL"
    },
    {
      "type": "url",
      "id": "nav_link_3_url",
      "label": "Nav link 3 — URL"
    },
    {
      "type": "text",
      "id": "menu_aria_label",
      "label": "Main menu — accessible name",
      "default": "Primary"
    },
    {
      "type": "text",
      "id": "search_aria_label",
      "label": "Search — accessible name",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "account_aria_label",
      "label": "Account — accessible name",
      "default": "Account"
    },
    {
      "type": "text",
      "id": "cart_aria_label",
      "label": "Cart — accessible name",
      "default": "Cart"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Eyebrow / kicker",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explore our curated collection of gifts for everyone on your list. From timeless classics to modern must-haves, find the perfect gift today.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "hero_illustration",
      "label": "Hero line-art background",
      "info": "Export from Figma (large PNG/SVG). Optional — layout works without it."
    }
  ],
  "presets": [
    {
      "name": "Ecomexperts — Gift guide banner"
    }
  ]
}
{% endschema %}
