{% comment %}
  Ecomexperts hiring test — Product grid with hotspots and quick-view popup.
  Six products + bundle product are configured in the theme editor.
{% endcomment %}

{{ 'ecomexperts-gift-guide.css' | asset_url | stylesheet_tag }}

<section
  class="ee-grid-section shopify-section"
  id="shopify-section-{{ section.id }}"
  data-ecomexperts-grid
  data-section-id="{{ section.id }}"
>
  <div class="ee-grid" role="list">
    {% for i in (1..6) %}
      {% assign pk = 'product_' | append: i %}
      {% assign p = section.settings[pk] %}
      {% assign ht = 'hotspot_' | append: i | append: '_top' %}
      {% assign hl = 'hotspot_' | append: i | append: '_left' %}
      {% assign hot_top = section.settings[ht] | default: 50 %}
      {% assign hot_left = section.settings[hl] | default: 50 %}

      <div class="ee-grid__cell" role="listitem" data-ee-slot="{{ i }}">
        {% if p != blank %}
          {% assign img = p.featured_image %}
          {% if img != blank %}
            <img
              class="ee-grid__img"
              src="{{ img | image_url: width: 1200 }}"
              alt="{{ p.title | escape }}"
              loading="lazy"
              width="{{ img.width }}"
              height="{{ img.height }}"
            >
          {% else %}
            <div class="ee-grid__placeholder">{{ 'content.placeholder_image' | t }}</div>
          {% endif %}

          <button
            type="button"
            class="ee-grid__hotspot"
            style="--ee-hot-y: {{ hot_top }}%; --ee-hot-x: {{ hot_left }}%;"
            data-ee-open-popup
            data-ee-slot-index="{{ i }}"
            aria-haspopup="dialog"
            aria-label="View product details — {{ p.title | escape }}"
          >
            <span class="ee-grid__hotspot-icon" aria-hidden="true"></span>
          </button>
        {% else %}
          <div class="ee-grid__placeholder">
            {{ section.settings.empty_slot_label | default: 'Select a product in the theme editor' }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div
    class="ee-modal"
    data-ee-modal
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="ee-modal-title-{{ section.id }}"
  >
    <div class="ee-modal__backdrop" data-ee-close-modal tabindex="-1"></div>
    <div class="ee-modal__dialog">
      <button type="button" class="ee-modal__close" data-ee-close-modal aria-label="{{ 'accessibility.close' | t }}">
        ×
      </button>
      <div class="ee-modal__body">
        <div class="ee-modal__media">
          <img class="ee-modal__media-img" data-ee-modal-image src="" alt="" width="600" height="800" loading="lazy">
        </div>
        <div class="ee-modal__detail">
          <h2
            class="ee-modal__title"
            id="ee-modal-title-{{ section.id }}"
            data-ee-modal-title
          ></h2>
          <p class="ee-modal__price" data-ee-modal-price></p>
          <div class="ee-modal__description rte" data-ee-modal-description></div>
          <div class="ee-modal__variants" data-ee-modal-variants></div>
          <p class="ee-modal__error" data-ee-modal-error role="status" aria-live="polite"></p>
          <button type="button" class="ee-modal__add" data-ee-modal-add>
            {{ section.settings.add_to_cart_label | default: 'ADD TO CART' }}
          </button>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-ee-grid-json>
    {% capture ee_grid_payload %}
    {
      "sectionId": {{ section.id | json }},
      "moneyFormat": {{ shop.money_format | json }},
      "currency": {{ cart.currency.iso_code | json }},
      "bundleProductId": {% if section.settings.bundle_product != blank %}{{ section.settings.bundle_product.id | json }}{% else %}null{% endif %},
      "bundleVariantId": {% if section.settings.bundle_product != blank %}{{ section.settings.bundle_product.selected_or_first_available_variant.id }}{% else %}null{% endif %},
      "rows": [
        {%- assign first_item = true -%}
        {%- for i in (1..6) -%}
          {%- assign pk = 'product_' | append: i -%}
          {%- assign p = section.settings[pk] -%}
          {%- if p != blank -%}
            {%- unless first_item -%},{%- endunless -%}
            {%- assign first_item = false -%}
            {%- assign ht = 'hotspot_' | append: i | append: '_top' -%}
            {%- assign hl = 'hotspot_' | append: i | append: '_left' -%}
            {
              "slot": {{ i }},
              "hotspotTop": {{ section.settings[ht] | default: 50 }},
              "hotspotLeft": {{ section.settings[hl] | default: 50 }},
              "product": {{ p | json }}
            }
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    {% endcapture %}
    {{ ee_grid_payload | strip_newlines }}
  </script>
</section>

<script src="{{ 'ecomexperts-gift-guide.js' | asset_url }}" type="module"></script>

